# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=shop_user
POSTGRES_PASSWORD=shop_pass
POSTGRES_DB=shop_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://shop_user:shop_pass@postgres:5432/shop_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
